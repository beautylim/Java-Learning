<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="org.example.shop.mapper.BlogMapper">
    <insert id="insert" parameterType="org.example.shop.model.entity.Blog" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO tb_blog (shop_id,title,content,user_id,tags,user_name)
        VALUES (#{shopId}, #{title}, #{content}, #{userId},#{tags}, #{userName})

    </insert>
    <update id="addLike" parameterType="java.lang.Long">
        update tb_blog set likes_count = likes_count + 1 where id = #{id}
    </update>

    <update id="update" parameterType="org.example.shop.model.entity.Blog"></update>
    <delete id="delete" parameterType="org.example.shop.model.entity.Blog">

    </delete>
    <update id="cancelLike" parameterType="java.lang.Long">
        update tb_blog set likes_count = likes_count - 1 where id = #{id}

    </update>
    <select id="selectById" resultType="org.example.shop.model.entity.Blog" parameterType="java.lang.Long">
        select * from tb_blog where id = #{id}
    </select>
    <select id="selectAll" resultType="org.example.shop.model.entity.Blog">
        select * from tb_blog
    </select>
    <select id="selectByUserId" resultType="org.example.shop.model.entity.Blog" parameterType="java.lang.Long">
        select * from tb_blog where user_id = #{userId}
    </select>
</mapper>