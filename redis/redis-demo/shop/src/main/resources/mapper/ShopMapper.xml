<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="org.example.shop.mapper.ShopMapper">
    <sql id="shopColumns">(shopName, address, logoPath, coverPath, tags, score)</sql>
    <insert id="insertShop" parameterType="org.example.shop.model.entity.Shop" useGeneratedKeys="true" keyProperty="id">
        insert into shop <include refid="shopColumns"></include>
               values (#{shopName}, #{address}, #{logoPath}, #{coverPath}, #{tags}, #{score})
    </insert>
    <insert id="insertShops" >
        insert into shop (shopName, address, logoPath, coverPath, tags, score)
        values 
            <foreach collection="shops" item="shop" separator=",">
                (#{shop.shopName}, #{shop.address}, #{shop.logoPath}, #{shop.coverPath}, #{shop.tags}, #{shop.score})
            </foreach>
    </insert>
    <update id="updateShop" parameterType="org.example.shop.model.entity.Shop">
        update shop
        set shopName = #{shopName},
            address = #{address},
            logoPath = #{logoPath},
            coverPath = #{coverPath},
            tags = #{tags},
            score = #{score}
        where id = #{id}
    </update>
    <update id="updateShopIgnoreNull" parameterType="org.example.shop.model.entity.Shop">
        update shop
        <set>
            <if test="shopName != null and shopName != ''">
                shopName = #{shopName},
            </if>
            <if test="address != null and address != ''">
                address = #{address},
            </if>
            <if test="logoPath != null and logoPath != ''">
                logoPath = #{logoPath},
            </if>
            <if test="coverPath != null and coverPath != ''">
                coverPath = #{coverPath},
            </if>
            <if test="tags != null and tags != ''">
                tags = #{tags},
            </if>
            <if test="score != null and score != ''">
                score = #{score},
            </if>
        </set>
        where id = #{id}
    </update>
    <select id="getShopById" resultType="org.example.shop.model.entity.Shop" parameterType="java.lang.Long">
        select id, shopName, address,logoPath,coverPath,tags, score from shop where id = #{id}
    </select>
    <select id="findAllShops" resultType="org.example.shop.model.entity.Shop">
        select id, shopName, address,logoPath,coverPath,tags, score,x,y from shop;
    </select>
    <select id="findShops" resultType="org.example.shop.model.entity.Shop">
        select id, shopName, address,logoPath,coverPath,tags, score from shop
        <where>
            <if test="name != null and name != ''">
                shopName = #{name}
            </if>
            <if test = "address != null and address !=''">
                and address like concat('%', #{address}, '%')
            </if>
        </where>
    </select>
    <select id="findShopsComplex" resultType="org.example.shop.model.entity.Shop">
        select id, shopName, address,logoPath,coverPath,tags, score from shop
        <trim prefix="where" suffixOverrides="and|or">
            <if test="name != null and name != ''">
                shopName like concat('%', #{name}, '%')  and
            </if>
            <if test = "address != null and address !=''">
                address like concat('%', #{address}, '%') and
            </if>
            <if test="tags != null and tags !=''">
                tags like concat('%', #{tags}, '%') and
            </if>
        </trim>
    </select>
    <select id="findShopsOnlyFromOneCondition" resultType="org.example.shop.model.entity.Shop">
        select id, shopName, address,logoPath,coverPath,tags, score from shop
        <where>
            <choose>
                <when test="name != null and name != ''">
                    shopName like concat('%', #{name}, '%')
                </when>
                <when test="address != null and address != ''">
                    address like concat('%', #{address}, '%')
                </when>
                <otherwise>
                    tags like concat('%', #{tags}, '%')
                </otherwise>
            </choose>
        </where>
    </select>
    <select id="findShopsByIds" resultType="org.example.shop.model.entity.Shop">
        select id, shopName, address,logoPath,coverPath,tags, score from shop
        where id in
        <foreach collection="ids" item="id" open="(" close=")" separator=",">
            #{id}
        </foreach>
    </select>
</mapper>